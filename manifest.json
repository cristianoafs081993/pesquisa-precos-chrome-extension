{
  "manifest_version": 3,
  "name": "Pesquisa de Precos - Compor",
  "description": "Automatiza regras de composicao e pesquisa complementar de mercado em pesquisas de precos.",
  "version": "2.5.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pesqpreco.estaleiro.serpro.gov.br/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Regra de Compor",
    "default_popup": "popup.html"
  }
}
